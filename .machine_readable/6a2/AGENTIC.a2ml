#
# AGENTIC.a2ml — AI agent constraints and capabilities for julianiser
# Defines what AI agents can and cannot do in this repository.

[metadata]
version = "0.1.0"
last-updated = "2026-03-21"

[agent-permissions]
can-edit-source = true
can-edit-tests = true
can-edit-docs = true
can-edit-config = true
can-create-files = true

[agent-constraints]
# What AI agents must NOT do:
# - Never use banned language patterns (believe_me, unsafeCoerce, etc.)
# - Never commit secrets or credentials
# - Never use banned languages (TypeScript, Python, Go, etc.) as implementation
# - Never place state files in repository root (must be in .machine_readable/)
# - Never use AGPL license (use PMPL-1.0-or-later)
# - Never write Julia by hand in this repo (Julia is only generated output)
# - Never confuse "parsing Python" with "using Python" — julianiser parses Python source but is written in Rust/Idris2/Zig

[julianiser-specific]
# Python/R are source-language targets (we parse them), not implementation languages
# Julia is the output language (we generate it), not hand-written here
# Idris2 ABI types: SourceLanguage, DataFrameOperation, ArrayPattern, JuliaType, EquivalenceWitness
# Zig FFI functions: julianiser_parse_python, julianiser_parse_r, julianiser_codegen, julianiser_benchmark

[maintenance-integrity]
fail-closed = true
require-evidence-per-step = true
allow-silent-skip = false
require-rerun-after-fix = true
release-claim-requires-hard-pass = true

[automation-hooks]
# on-enter: Read 0-AI-MANIFEST.a2ml, then STATE.a2ml
# on-exit: Update STATE.a2ml with session outcomes
# on-commit: Run just validate-rsr
